{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": ["./*"],
      "content-collections": [".content-collections/generated"],
      "@workspace/map": ["../../packages/map/src/index.ts"],
      "@workspace/map/*": ["../../packages/map/src/*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "fumadocs-mdx:collections/*": [".source/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".content-collections/generated/**/*.d.ts",
    ".source/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
